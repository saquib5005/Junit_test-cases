    @Test
    void testCreateSwiftletFlowsFromXml_RoutingSetupNotFound_ThrowsBadRequestException() throws Exception {
        when(mockFile.isEmpty()).thenReturn(false);
        when(mockFile.getBytes()).thenReturn(new byte[]{1, 2, 3});
        
        ElTnxRecord dummyRecord = new ElTnxRecord();
        dummyRecord.setBeneficiaryReference("BENE123");
        dummyRecord.setBoRefId("BOREF123");

        try (MockedStatic<ZipUtils> zipUtilsMock = mockStatic(ZipUtils.class);
             MockedStatic<XmlUtils> xmlUtilsMock = mockStatic(XmlUtils.class);
             MockedStatic<DigestUtils> digestUtilsMock = mockStatic(DigestUtils.class)) {
            
            when(mockXmlFile.getOriginalFilename()).thenReturn("data.xml");
            zipUtilsMock.when(() -> ZipUtils.extractZipFiles(mockFile)).thenReturn(List.of(mockXmlFile));
            xmlUtilsMock.when(() -> XmlUtils.unmarshalWithoutIntrospector(any(), eq(ElTnxRecord.class))).thenReturn(dummyRecord);
            xmlUtilsMock.when(() -> XmlUtils.marshall(any(), eq(ElTnxRecord.class))).thenReturn("<xml></xml>");
            digestUtilsMock.when(() -> DigestUtils.sha256Hex(anyString())).thenReturn("CHECKSUM123");

            // Mock routing not found
            when(routingSetupService.findRoutingSetupByCriteria(any(RoutingSetupCriteriaDto.class))).thenReturn(null);
            
            when(errorCodeSetupService.findByErrorCode(TchErrorCode.ROUTING_NOT_FOUND.getCode())).thenReturn(mockErrorCodeSetup);
            when(mockErrorCodeSetup.getDescription()).thenReturn("Routing Not Found");

            BadRequestException exception = assertThrows(BadRequestException.class, 
                () -> dpProcessingService.createSwiftletFlowsFromXml(mockFile));
            
            assertEquals("Routing Not Found", exception.getMessage());
            verify(errorLogHandler).logError(any(), any(), isNull(), eq(DpProcessingServiceImpl.class));
        }
    }

