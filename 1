    @Test
    void testMapFileActFlow_WithProdService() {
        // swiftUseTestBic contains "false" as initialized in @BeforeEach
        String zipFileName = "my_archive.zip";
        
        DpFileActFlow result = dpProcessingService.mapFileActFlow(zipFileName);
        
        assertEquals(DpProcessingServiceImpl.FILE_ACT_FLOW_REQUEST_TYPE, result.getRequestType());
        assertEquals(DpProcessingServiceImpl.FILE_ACT_FLOW_SERVICE_NAME_PROD, result.getServiceName());
        assertEquals(DpProcessingServiceImpl.FILE_ACT_FLOW_FILE_INFO, result.getFileInfo());
        assertEquals(DpProcessingServiceImpl.FILE_ACT_FLOW_JURIDICTION, result.getJuridiction());
        assertEquals(Long.valueOf(zipFileName.length()), result.getFileSize());
        assertEquals(zipFileName, result.getFileName());
        assertEquals(zipFileName, result.getOriginalName());
        assertEquals(zipFileName, result.getLogicalName());
    }

