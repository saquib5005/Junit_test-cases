    @Test
    void testUpdateFileActFlow_EmptyFileList_ReturnsNull() {
        DpTransaction transaction = new DpTransaction();
        when(fileActFlowService.findFileActFlowByFileNameAndTypeAndDirection(
            "test.zip", FileActType.HEADER, Direction.OUT)).thenReturn(Collections.emptyList());

        DpFileActFlow result = dpProcessingService.updateFileActFlow(transaction, "test.zip");
        assertNull(result);
    }

    @Test
    void testUpdateFileActFlow_Success_UpdatesAndReturnsFlow() {
        DpTransaction transaction = new DpTransaction();
        transaction.setSenderId("SENDER123");
        transaction.setReceiverId("RECEIVER123");
        
        DpFileActFlow mockFlow = new DpFileActFlow();
        when(fileActFlowService.findFileActFlowByFileNameAndTypeAndDirection(
            "test.zip", FileActType.HEADER, Direction.OUT)).thenReturn(List.of(mockFlow));
        
        when(fileActFlowService.getUnicRefFromSupplier()).thenReturn("UNIC_REF_123");
        when(fileActFlowService.update(any(DpFileActFlow.class))).thenReturn(mockFlow);

        DpFileActFlow result = dpProcessingService.updateFileActFlow(transaction, "test.zip");
        
        assertNotNull(result);
        assertEquals("SENDER123", result.getRequestorDn());
        assertEquals("RECEIVER123", result.getResponderDn());
        assertEquals("UNIC_REF_123", result.getUnicRef());
        verify(transactionService).saveTransaction(transaction);
        assertEquals("test.zip", transaction.getFileName());
    }

    // ========================================================================
