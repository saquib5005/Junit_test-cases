private static BeneficiaryType buildBeneficiaryForSR2026(ElTnxRecord elTnxRecord) {
    BeneficiaryType benefType = new BeneficiaryType();
    ZCharacterSymbol354Type field59N = new ZCharacterSymbol354Type();
    
    if (StringUtils.isNotEmpty(elTnxRecord.getBeneficiaryAbbvName())) { 
        field59N.getLine().add(elTnxRecord.getBeneficiaryAbbvName()); 
        benefType.setField59N(field59N);
    }

    ZCharacterSymbol354Type field59S = new ZCharacterSymbol354Type();
    if (StringUtils.isNotEmpty(elTnxRecord.getBeneficiaryAddressLinel())) { 
        field59S.getLine().add(elTnxRecord.getBeneficiaryAddressLinel());
    }
    if (StringUtils.isNotEmpty(elTnxRecord.getBeneficiaryAddressLine2())) { 
        field59S.getLine().add(elTnxRecord.getBeneficiaryAddressLine2());
    }
    if (StringUtils.isNotEmpty(elTnxRecord.getBeneficiaryDom())) { 
        field59S.getLine().add(elTnxRecord.getBeneficiaryDom());
    }
    benefType.setField59S(field59S);

    // Extracted nested 'if' logic to keep complexity low
    buildAddressForSR2026(elTnxRecord.getBeneficiaryAddress(), benefType);

    return benefType;
}

