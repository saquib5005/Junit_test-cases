    @Test
    void testSaveFileAttachmentToS3_Success() {
        DpFileActFlow fileActFlow = new DpFileActFlow();
        byte[] zipFile = new byte[]{1, 2, 3};
        String fileName = "attachment.zip";

        String result = dpProcessingService.saveFileAttachmentToS3(fileActFlow, zipFile, fileName);

        verify(documentReportService).uploadFileS3(zipFile, "/test/s3/path/attachment.zip", false);
        assertEquals(fileName, result);
        assertEquals(fileName, fileActFlow.getFileName());
        assertEquals(fileName, fileActFlow.getLogicalName());
        assertEquals("attachment", fileActFlow.getUnicRef()); // Extracts correctly without .zip
        
        verify(fileActFlowService).processFileActFlow(
            fileActFlow, TransactionStatus.RECEIVED, MandatoryType.NO, FileActType.HEADER, Direction.OUT);
    }

    @Test
    void testSaveFileAttachmentToS3_NullFileName() {
        DpFileActFlow fileActFlow = new DpFileActFlow();
        byte[] zipFile = new byte[]{1, 2, 3};

        String result = dpProcessingService.saveFileAttachmentToS3(fileActFlow, zipFile, null);

        // Verifies the file still uploads, but doesn't set properties on the flow since fileName is null
        verify(documentReportService).uploadFileS3(zipFile, "/test/s3/path/null", false);
        assertNull(result);
        assertNull(fileActFlow.getFileName());
    }

