    @Test
    void testCreateSwiftletFlowsFromXml_EmptyFile_ThrowsBadRequestException() {
        when(mockFile.isEmpty()).thenReturn(true);
        when(errorCodeSetupService.findByErrorCode(anyString())).thenReturn(mockErrorCodeSetup);
        when(mockErrorCodeSetup.getDescription()).thenReturn("Empty File");

        BadRequestException exception = assertThrows(BadRequestException.class, 
            () -> dpProcessingService.createSwiftletFlowsFromXml(mockFile));
        
        assertEquals("Empty File", exception.getMessage());
        verify(errorMessageService).registerError(null, null, mockErrorCodeSetup, null, null);
    }

