private static void buildAddressForSR2026(AddressType addressType, BeneficiaryType benefType) {
    // Guard clause prevents nesting
    if (addressType == null) {
        return;
    }

    BenefAddressType addr = new BenefAddressType();
    
    if (StringUtils.isNotEmpty(addressType.getTownName())) { 
        addr.setField59T(addressType.getTownName());
    }
    if (StringUtils.isNotEmpty(addressType.getPostCode())) { 
        addr.setField59P(addressType.getPostCode());
    }
    if (StringUtils.isNotEmpty(addressType.getCountry())) {
        addr.setField59R(addressType.getCountry());
    }
    
    benefType.setBeneficiaryAddress(addr);
}

