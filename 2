    @Test
    void testCreateSwiftletFlowsFromXml_FullRouting_WithFiles_Success() throws Exception {
        when(mockFile.isEmpty()).thenReturn(false);
        when(mockFile.getBytes()).thenReturn(new byte[]{1, 2, 3});

        ElTnxRecord dummyRecord = new ElTnxRecord();
        RoutingSetup mockRouting = new RoutingSetup();
        mockRouting.setId(1L);
        mockRouting.setBankBic("TESTBANK");
        mockRouting.setCustomerBic("CUSTBIC");

        DpSwiftMsgType mockMsgType = new DpSwiftMsgType();
        mockMsgType.setProcessName("Process1");

        odMessageDto mockMxMessage = new odMessageDto();

        try (MockedStatic<ZipUtils> zipUtilsMock = mockStatic(ZipUtils.class);
             MockedStatic<XmlUtils> xmlUtilsMock = mockStatic(XmlUtils.class);
             MockedStatic<DigestUtils> digestUtilsMock = mockStatic(DigestUtils.class)) {

            // 1. Setup File and Extraction
            when(mockXmlFile.getOriginalFilename()).thenReturn("data.xml");
            zipUtilsMock.when(() -> ZipUtils.extractZipFiles(mockFile)).thenReturn(List.of(mockXmlFile, mockFile)); // 2 files to trigger file zipping
            zipUtilsMock.when(() -> ZipUtils.createZipFiles(anyList())).thenReturn(new byte[]{9, 9, 9});

            // 2. Setup XML Parsing
            xmlUtilsMock.when(() -> XmlUtils.unmarshalWithoutIntrospector(any(), eq(ElTnxRecord.class))).thenReturn(dummyRecord);
            xmlUtilsMock.when(() -> XmlUtils.marshall(any(), eq(ElTnxRecord.class))).thenReturn("<xml></xml>");
            digestUtilsMock.when(() -> DigestUtils.sha256Hex(anyString())).thenReturn("CHECKSUM");

            // 3. Setup Routing and Transaction
            when(routingSetupService.findRoutingSetupByCriteria(any())).thenReturn(mockRouting);
            when(routingSetupService.getTestBic(any())).thenReturn("TESTBIC");
            when(requestService.saveRequest(any())).thenReturn(new DpXmlRequest());
            
            // 4. Force into processTransactionWithRouting
            when(swiftMsgTypeService.findSwiftMsgTypeByCriteria(any(), eq(FlowDirection.B2C))).thenReturn(List.of(mockMsgType));
            
            // 5. Force processReceivedSwiftMsgTypeList into the MX path (list is not empty)
            when(swiftService.convertToMxMessageList(any(), any(), any(), any(), any(), anyBoolean()))
                .thenReturn(List.of(mockMxMessage)); // Bypasses the complex MT fallback

            // 6. Setup FileAct Flow
            when(fileActFlowService.getUnicRefFromSupplier()).thenReturn("UNIC_REF_123");
            DpFileActFlow mockFileActFlow = new DpFileActFlow();
            when(fileActFlowService.findFileActFlowByFileNameAndTypeAndDirection(anyString(), any(), any()))
                .thenReturn(List.of(mockFileActFlow));
            when(fileActFlowService.update(any())).thenReturn(mockFileActFlow);

            // Execute
            boolean result = dpProcessingService.createSwiftletFlowsFromXml(mockFile);

            // Assertions & Verifications
            assertTrue(result);
            verify(transactionService, atLeastOnce()).saveTransaction(any(DpTransaction.class));
            verify(documentReportService, atLeastOnce()).uploadFileS3(any(), anyString(), anyBoolean());
            
            // Verifies sendFileActMessageIfNeeded was triggered
            verify(fileActSender).sendFileActMessage(any(DpFileActFlow.class), any(byte[].class));
        }
    }

    @Test
    void testCreateSwiftletFlowsFromXml_GenericException_HandledCorrectly() throws Exception {
        when(mockFile.isEmpty()).thenReturn(false);
        when(mockFile.getBytes()).thenReturn(new byte[]{1, 2, 3});
        
        try (MockedStatic<ZipUtils> zipUtilsMock = mockStatic(ZipUtils.class);
             MockedStatic<XmlUtils> xmlUtilsMock = mockStatic(XmlUtils.class)) {
            
            when(mockXmlFile.getOriginalFilename()).thenReturn("data.xml");
            zipUtilsMock.when(() -> ZipUtils.extractZipFiles(mockFile)).thenReturn(List.of(mockXmlFile));
            xmlUtilsMock.when(() -> XmlUtils.unmarshalWithoutIntrospector(any(), eq(ElTnxRecord.class))).thenReturn(new ElTnxRecord());
            xmlUtilsMock.when(() -> XmlUtils.marshall(any(), eq(ElTnxRecord.class))).thenReturn("<xml></xml>");
            
            // Force a generic exception early in processElcOutgoing
            when(requestService.saveRequest(any())).thenThrow(new RuntimeException("Database down"));
            
            when(errorCodeSetupService.findByErrorCode(TchErrorCode.ERR_MAPPING_REQUEST.getCode())).thenReturn(mockErrorCodeSetup);

            assertThrows(TchBusinessException.class, 
                () -> dpProcessingService.createSwiftletFlowsFromXml(mockFile));
                
            // Verifies handleGenericError was called
            verify(errorLogHandler).logError(any(), any(), isNull(), eq(DpProcessingServiceImpl.class));
            verify(errorMessageService).registerOutgoingError(any(), any(), any(), eq("Database down"), isNull());
        }
    }

